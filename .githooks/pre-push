#!/bin/bash
# Pre-push guard: runs lint + type + test before allowing push.
# This is what PR-Agent would flag — catch it locally first.
set -e

echo "=== pre-push: ruff check ==="
python3 -m ruff check src tests || { echo "❌ ruff failed. Fix and retry."; exit 1; }

echo "=== pre-push: ruff format ==="
python3 -m ruff format --check src tests || { echo "❌ ruff format failed. Run 'make fmt'."; exit 1; }

echo "=== pre-push: mypy ==="
python3 -m mypy || { echo "❌ mypy failed."; exit 1; }

echo "=== pre-push: pytest ==="
python3 -m pytest -q || { echo "❌ tests failed."; exit 1; }

echo "✅ pre-push checks passed."
